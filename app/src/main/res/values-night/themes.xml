<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Wakify" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/wakify_primary</item>
        <item name="colorOnPrimary">@color/wakify_on_primary</item>
        <item name="colorPrimaryContainer">@color/wakify_surface_variant</item>
        <item name="colorSecondary">@color/wakify_secondary</item>
        <item name="colorOnSecondary">@color/wakify_on_secondary</item>
        <item name="colorSurface">@color/wakify_surface</item>
        <item name="colorOnSurface">@color/wakify_on_surface</item>
        <item name="colorSurfaceVariant">@color/wakify_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/wakify_on_surface_variant</item>
        <item name="colorError">@color/wakify_error</item>
        <item name="colorOnError">@color/wakify_on_error</item>
        <item name="colorOutline">@color/wakify_outline</item>
        <item name="android:colorBackground">@color/wakify_background</item>
        <item name="android:statusBarColor">@color/wakify_background</item>
        <item name="android:navigationBarColor">@color/wakify_background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.Wakify.FullScreen" parent="Theme.Wakify">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/wakify_step_bg</item>
    </style>

    <style name="ShapeAppearanceOverlay.Wakify.Fab" parent="">
        <item name="cornerSize">16dp</item>
    </style>

</resources>
